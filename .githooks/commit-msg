#!/bin/sh
# .githooks/commit-msg — 教师资源发展平台 (China Teacher Resources Development Platform).
# Enforces Conventional Commits on the first line of the commit message.
# Merge and revert commits are allowed through unchanged.

MSG_FILE="$1"
[ -z "$MSG_FILE" ] && exit 0
[ -f "$MSG_FILE" ] || exit 0

# First non-empty line of the message.
FIRST_LINE="$(grep -v '^[[:space:]]*#' "$MSG_FILE" | sed '/^[[:space:]]*$/d' | head -n 1)"

# Allow merge / revert / fixup / squash commits through.
case "$FIRST_LINE" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*|"Reapply "*)
    exit 0
    ;;
esac

# Conventional Commits: type(scope)!: subject
PATTERN='^(feat|fix|docs|design|harness|test|chore|refactor|ci|build|perf)(\(.+\))?!?: .{1,}'

if printf '%s' "$FIRST_LINE" | grep -Eq "$PATTERN"; then
  exit 0
fi

echo "✗ Commit message does not follow Conventional Commits." >&2
echo "" >&2
echo "  Expected:  <type>(<scope>)?!?: <subject>" >&2
echo "  Types:     feat fix docs design harness test chore refactor ci build perf" >&2
echo "" >&2
echo "  Examples:" >&2
echo "    feat(companion-agent): add closure-loop validation to the state engine" >&2
echo "    fix: correct full-width punctuation in the PRD" >&2
echo "    docs(glossary): clarify 陪跑智能体 canonical term" >&2
echo "    harness!: make gate block on P2 style findings" >&2
echo "" >&2
echo "  Your first line was:" >&2
echo "    $FIRST_LINE" >&2
exit 1
